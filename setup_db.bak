-- Run this in MySQL to set up your database
 
CREATE DATABASE IF NOT EXISTS analytics_db;
USE analytics_db;
 
CREATE TABLE IF NOT EXISTS users (
    id INT AUTO_INCREMENT PRIMARY KEY,
    username VARCHAR(100) NOT NULL UNIQUE,
    password VARCHAR(255) NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);
 
-- Create a dedicated MySQL user for the app
CREATE USER IF NOT EXISTS 'analytics_user'@'localhost' IDENTIFIED BY 'YOUR_DB_PASSWORD';
GRANT ALL PRIVILEGES ON analytics_db.* TO 'analytics_user'@'localhost';
FLUSH PRIVILEGES;